{
  "name": "@bunnykit/storage",
  "version": "1.2.0",
  "description": "Laravel Storage-inspired file storage abstraction for Bun. Supports local disk and S3-compatible backends.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --minify --splitting --external @bunnykit/orm && bunx tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prebuild": "bun run clean",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "peerDependencies": {
    "@bunnykit/orm": "*"
  },
  "peerDependenciesMeta": {
    "@bunnykit/orm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@bunnykit/orm": "latest",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@types/bun": "latest",
    "semantic-release": "^24.0.0",
    "typescript": "^5.0.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "keywords": [
    "storage",
    "s3",
    "r2",
    "bun",
    "laravel"
  ],
  "author": {
    "name": "Junrey Beduya",
    "email": "jbeduya@gmail.com"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
